{
  "name": "synergybusiness",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "typecheck": "pnpm --filter web typecheck",
    "db:generate": "pnpm --filter web exec drizzle-kit generate --config=../../packages/db/drizzle.config.ts",
    "db:push": "pnpm --filter web exec drizzle-kit push --config=../../packages/db/drizzle.config.ts",
    "db:migrate": "pnpm --filter web exec drizzle-kit migrate --config=../../packages/db/drizzle.config.ts",
    "db:studio": "pnpm --filter web exec drizzle-kit studio --config=../../packages/db/drizzle.config.ts"
  },
  "workspaces": ["apps/*", "packages/*"]
}
