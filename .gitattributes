* text=auto eol=lf

# Shell scripts MUST be LF — Windows CRLF breaks them on Linux.
*.sh        text eol=lf
*.bash      text eol=lf

# Other deployment configs that run on Linux
nginx-*.conf text eol=lf

# Binary files
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.zip       binary
*.gz        binary
